# ===== Microsoft Foundry =====
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-mini
FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ===== Azure AI Search =====
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_HR_INDEX=hr-policies
AZURE_SEARCH_CLINICAL_INDEX=clinical-laser
AZURE_SEARCH_MAINTENANCE_INDEX=maintenance-kb

# ===== Azure resources =====
AZURE_KEYVAULT_URI=https://<your-kv>.vault.azure.net/
AZURE_COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
AZURE_COSMOS_DATABASE=foundry-workload-studio
AZURE_STORAGE_ACCOUNT=<your-storage>
AZURE_STORAGE_CONTAINER=documents
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ===== Runtime =====
ENVIRONMENT=dev
LOG_LEVEL=INFO
ENABLE_TELEMETRY=true
